{
  "name": "smart-proxy-route-helper",
  "version": "0.1.0",
  "private": true,
  "description": "Manifest V3 local proxy routing manager for Chrome.",
  "type": "module",
  "scripts": {
    "build": "tsc --noEmit && vite build",
    "build:local-stable-id": "node scripts/build-local-stable-id.mjs",
